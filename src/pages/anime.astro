---
import { Icon } from "astro-icon/components";
import AnimeGrid from "@/components/pages/anime/AnimeGrid.svelte";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getAnimePageData } from "@/utils/anime-utils";

// 检查页面是否启用
if (!siteConfig.pages.anime) {
	return Astro.redirect("/404/");
}

const {
	animeList,
	totalCount,
	tmdbAverageRating,
	bilibiliAverageRating,
	isConfigured,
	sourceLabel,
} = await getAnimePageData();
---

<MainGridLayout title={i18n(I18nKey.anime)} description={i18n(I18nKey.animeSubtitle)}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-4 sm:px-6 md:px-9 py-4 sm:py-6 relative w-full">
      <!-- 页面标题 -->
      <div class="relative w-full mb-8">
        <div class="mb-6">
          <div class="flex items-center gap-3 mb-3">
            <div class="h-9 w-9 rounded-xl bg-gradient-to-br from-(--primary) to-(--primary)/80 flex items-center justify-center text-white shadow-lg shadow-(--primary)/30">
              <Icon name="material-symbols:live-tv" class="text-[1.4rem]"></Icon>
            </div>
            <div class="text-2xl sm:text-3xl font-bold text-neutral-900 dark:text-neutral-100">
              {i18n(I18nKey.anime)}
            </div>
          </div>
          <p class="text-sm sm:text-base text-neutral-500 dark:text-neutral-400 leading-relaxed">
            {i18n(I18nKey.animeSubtitle)}
          </p>
        </div>

        {!isConfigured ? (
          <!-- 未配置提示 -->
          <div class="text-center py-16">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-(--btn-regular-bg) rounded-full mb-6 border border-(--line-divider)">
              <Icon name="material-symbols:settings" class="text-[2rem] text-(--btn-content)" />
            </div>
            <h2 class="text-xl font-semibold text-black/80 dark:text-white/80 mb-3">
              {i18n(I18nKey.animeNotConfigured)}
            </h2>
            <p class="text-black/60 dark:text-white/60 mb-4 max-w-md mx-auto">
              {i18n(I18nKey.animeNotConfiguredDesc)}
            </p>
          </div>
        ) : (
          <>
            <!-- 统计卡片 -->
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
              <div class="bg-(--card-bg) rounded-2xl p-4 sm:p-5 border border-(--line-divider) transition-all duration-200 hover:shadow-md hover:border-(--primary)/30">
                <div class="flex items-center gap-3">
                  <div class="h-10 w-10 sm:h-11 sm:w-11 rounded-xl bg-(--primary)/10 flex items-center justify-center shrink-0">
                    <Icon name="material-symbols:movie-filter" class="text-[1.1rem] sm:text-[1.25rem] text-(--primary)" />
                  </div>
                  <div class="min-w-0">
                    <div class="text-[11px] sm:text-xs text-neutral-500 dark:text-neutral-400 font-medium">{i18n(I18nKey.animeTotal)}</div>
                    <div class="text-xl sm:text-2xl font-bold text-neutral-900 dark:text-neutral-100">{totalCount}</div>
                  </div>
                </div>
              </div>
              <div class="bg-(--card-bg) rounded-2xl p-4 sm:p-5 border border-(--line-divider) transition-all duration-200 hover:shadow-md hover:border-pink-500/30">
                <div class="flex items-center gap-3">
                  <div class="h-10 w-10 sm:h-11 sm:w-11 rounded-xl bg-pink-500/10 flex items-center justify-center shrink-0">
                    <Icon name="material-symbols:favorite" class="text-[1.1rem] sm:text-[1.25rem] text-pink-500" />
                  </div>
                  <div class="min-w-0">
                    <div class="text-[11px] sm:text-xs text-neutral-500 dark:text-neutral-400 font-medium">{i18n(I18nKey.animeBilibiliAvg)}</div>
                    <div class="text-xl sm:text-2xl font-bold text-neutral-900 dark:text-neutral-100">{bilibiliAverageRating}</div>
                  </div>
                </div>
              </div>
              <div class="bg-(--card-bg) rounded-2xl p-4 sm:p-5 border border-(--line-divider) transition-all duration-200 hover:shadow-md hover:border-yellow-500/30">
                <div class="flex items-center gap-3">
                  <div class="h-10 w-10 sm:h-11 sm:w-11 rounded-xl bg-yellow-500/10 flex items-center justify-center shrink-0">
                    <Icon name="material-symbols:star" class="text-[1.1rem] sm:text-[1.25rem] text-yellow-500" />
                  </div>
                  <div class="min-w-0">
                    <div class="text-[11px] sm:text-xs text-neutral-500 dark:text-neutral-400 font-medium">{i18n(I18nKey.animeTmdbAvg)}</div>
                    <div class="text-xl sm:text-2xl font-bold text-neutral-900 dark:text-neutral-100">{tmdbAverageRating}</div>
                  </div>
                </div>
              </div>
              <div class="bg-(--card-bg) rounded-2xl p-4 sm:p-5 border border-(--line-divider) transition-all duration-200 hover:shadow-md hover:border-emerald-500/30">
                <div class="flex items-center gap-3">
                  <div class="h-10 w-10 sm:h-11 sm:w-11 rounded-xl bg-emerald-500/10 flex items-center justify-center shrink-0">
                    <Icon name="material-symbols:database" class="text-[1.1rem] sm:text-[1.25rem] text-emerald-500" />
                  </div>
                  <div class="min-w-0">
                    <div class="text-[11px] sm:text-xs text-neutral-500 dark:text-neutral-400 font-medium">{i18n(I18nKey.animeSource)}</div>
                    <div class="text-sm sm:text-base font-bold leading-tight text-neutral-900 dark:text-neutral-100">
                      {sourceLabel}
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- 番剧网格（Svelte 交互组件） -->
            <AnimeGrid
              client:visible
              items={animeList}
              bilibiliAverageRating={bilibiliAverageRating}
            />
          </>
        )}
      </div>
    </div>
  </div>
</MainGridLayout>
